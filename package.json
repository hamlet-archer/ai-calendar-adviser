{
  "name": "@hamlet-archer/ai-calendar-adviser",
  "version": "0.0.0",
  "description": "Read-only RPC over Google Calendar for the ai-ops fleet. Backs Phase 3 task body enrichment grounding (## Constraints).",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . --max-warnings=0 && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hamlet-archer/ai-ops-control-plane": "git+https://github.com/hamlet-archer/ai-ops-control-plane.git#v0.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
