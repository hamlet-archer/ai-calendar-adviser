# ai-calendar-adviser environment configuration.
#
# Auth: per-user OAuth on ai@liao.info (G6.5a + G6.5b + G6.5c). Per
# `feedback_no_kelvin_account_impersonation` this agent never
# authenticates as Kelvin's account, and Kelvin's calendars are NOT
# reachable from this code path (the handler returns a documented
# `unavailable` envelope when `person='kelvin'`).
#
# Refresh token bootstrap (one-time, Kelvin's mac):
#   tsx src/scripts/bootstrap-oauth.ts --subject=ai@liao.info \
#                                      --scopes=calendar.readonly
# Output token JSON ⇒ scp to /etc/ai-calendar-adviser/oauth-token.json
# (mode 0600) on golden-ai-ops.

# Path to the per-user OAuth refresh-token JSON (mode 0600). On golden-
# ai-ops, systemd LoadCredential resolves this to
# $CREDENTIALS_DIRECTORY/oauth-token.
OAUTH_TOKEN_PATH=/etc/ai-calendar-adviser/oauth-token.json

# Optional override of the authenticated subject. Defaults to
# `ai@liao.info`. The adapter REJECTS `kelvin@liao.info` at load time
# regardless of token contents (`feedback_no_kelvin_account_impersonation`).
# OAUTH_SUBJECT=ai@liao.info

# Calendar slot ids. G6.5c dropped the kelvin-only `primary` + `others`
# slots — the agent only reads non-Kelvin shared calendars now.
CALENDAR_ID_MKKK=mkkk@group.calendar.google.com
CALENDAR_ID_MKKK_OTHERS=mkkk-others@group.calendar.google.com
CALENDAR_ID_STAFF=c_552a7b...@group.calendar.google.com

# Local cache + RPC socket paths.
CALENDAR_DB_PATH=/var/lib/ai-calendar-adviser/calendar.db
CALENDAR_SOCKET_PATH=/run/ai-calendar-adviser/query.sock
